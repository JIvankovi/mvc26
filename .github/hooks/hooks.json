{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "powershell": "Add-Content -Path logs/session.log -Value \"Session started: $(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')\" -Encoding UTF8",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "powershell": ".github/scripts/log-prompt.ps1",
        "cwd": ".",
        "timeoutSec": 10
      }
    ]
  }
}
