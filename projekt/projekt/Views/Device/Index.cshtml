@model List<projekt.Models.Device>

@{
    ViewData["Title"] = "Devices";
}

<div class="container mt-5">
    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="display-4">
                <span class="badge bg-primary">Devices</span>
            </h1>
            <p class="text-muted">Manage and view all laboratory devices</p>
        </div>
        <div class="col-md-4 text-end">
            
        </div>
    </div>

    <!-- Content Section -->
    @if (Model != null && Model.Count > 0)
    {
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Registered Devices</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-light">
                            <tr>
                                <th scope="col" class="text-center" style="width: 60px;">ID</th>
                                <th scope="col">Name</th>
                                <th scope="col">Manufacturer</th>
                                <th scope="col">Serial Number</th>
                                <th scope="col">Purchase Date</th>
                                <th scope="col" class="text-center" style="width: 120px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var device in Model)
                            {
                                <tr>
                                    <td class="text-center">
                                        <span class="badge bg-secondary">@device.Id</span>
                                    </td>
                                    <td>
                                        <strong>@device.Name</strong>
                                    </td>
                                    <td>@device.Manufacturer</td>
                                    <td>
                                        <code>@device.SerialNumber</code>
                                    </td>
                                    <td>
                                        @device.PurchaseDate.ToShortDateString()
                                    </td>
                                    <td class="text-center">
                                        <a href="@Url.Action("Details", "Device", new { id = device.Id })" class="btn btn-sm btn-info">
                                            <i class="bi bi-eye"></i> Details
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <strong>No devices found!</strong> There are currently no devices in the database.
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
</div>

<style>
    .card {
        border: none;
        border-radius: 0.5rem;
    }

    .table th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
    }

    .table tbody tr {
        transition: background-color 0.15s ease-in-out;
    }

    .btn-sm {
        padding: 0.375rem 0.75rem;
        font-size: 0.875rem;
    }

    .display-4 {
        font-weight: 700;
    }

    code {
        background-color: #f4f4f4;
        padding: 0.2rem 0.4rem;
        border-radius: 0.25rem;
        font-size: 0.9em;
    }
</style>
