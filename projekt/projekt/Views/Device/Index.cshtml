@model List<projekt.Models.Device>

@{
    ViewData["Title"] = "Devices";
}

<div class="container mt-5">
    <div class="row mb-4 align-items-end">
        <div class="col-md-6">
            <h1 class="display-5">Devices</h1>
            <p class="text-muted">Search, review and manage devices with an AJAX-powered list.</p>
        </div>
        <div class="col-md-6 text-end">
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" asp-controller="Device" class="btn btn-primary">Add Device</a>
            }
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-8">
            <div class="input-group shadow-sm">
                <span class="input-group-text">Search</span>
                <input id="device-search" class="form-control" placeholder="Enter device name, manufacturer or serial number" />
                <button id="device-search-clear" type="button" class="btn btn-outline-secondary">Clear</button>
            </div>
        </div>
    </div>

    <div id="device-table-container" data-search-url="@Url.Action("Search", "Device")">
        @await Html.PartialAsync("_DeviceTable", Model)
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        $(function () {
            lab4.initSearch("#device-search", "#device-table-container", "@Url.Action("Search", "Device")");
        });
    </script>
}
