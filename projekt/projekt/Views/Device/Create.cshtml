@model projekt.ViewModels.DeviceFormViewModel

@{
    ViewData["Title"] = "Create Device";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="display-5">Create Device</h1>
            <p class="text-muted">Use this form to add a new device to the inventory.</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Index" asp-controller="Device" class="btn btn-outline-secondary">Back to Devices</a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <form asp-action="Create" method="post" novalidate>
                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Manufacturer" class="form-label"></label>
                    <input asp-for="Manufacturer" class="form-control" />
                    <span asp-validation-for="Manufacturer" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="SerialNumber" class="form-label"></label>
                    <input asp-for="SerialNumber" class="form-control" />
                    <span asp-validation-for="SerialNumber" class="text-danger"></span>
                </div>
                @await Html.PartialAsync("_DateTimeControl", new projekt.ViewModels.DateTimeControlViewModel
                {
                    FieldName = "PurchaseDate",
                    Label = "Purchase Date",
                    Value = Model.PurchaseDate,
                    Required = false
                })
                <div class="mb-3">
                    <label asp-for="MeasurementType" class="form-label"></label>
                    <select asp-for="MeasurementType" class="form-select" asp-items="Html.GetEnumSelectList<projekt.Models.MeasurementType>()"></select>
                    <span asp-validation-for="MeasurementType" class="text-danger"></span>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Save Device</button>
                    <a asp-action="Index" asp-controller="Device" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
