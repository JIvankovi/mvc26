@model projekt.Models.Device

@{
    ViewData["Title"] = "Delete Device";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="display-5">Delete Device</h1>
            <p class="text-muted">Confirm removal of this device. This operation cannot be undone.</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Index" asp-controller="Device" class="btn btn-outline-secondary">Back to Devices</a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <h5 class="mb-3">Device summary</h5>
            <dl class="row">
                <dt class="col-sm-4">ID</dt>
                <dd class="col-sm-8">@Model.Id</dd>

                <dt class="col-sm-4">Name</dt>
                <dd class="col-sm-8">@Model.Name</dd>

                <dt class="col-sm-4">Manufacturer</dt>
                <dd class="col-sm-8">@Model.Manufacturer</dd>

                <dt class="col-sm-4">Serial Number</dt>
                <dd class="col-sm-8">@Model.SerialNumber</dd>

                <dt class="col-sm-4">Purchase Date</dt>
                <dd class="col-sm-8">@Model.PurchaseDate?.ToString("dd.MM.yyyy")</dd>
            </dl>

            <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                @if (User.IsInRole("Admin"))
                {
                    <button type="submit" class="btn btn-danger">Delete Device</button>
                }
                <a asp-action="Index" asp-controller="Device" class="btn btn-secondary ms-2">Cancel</a>
            </form>
        </div>
    </div>
</div>
