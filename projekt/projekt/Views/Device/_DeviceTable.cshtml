@model List<projekt.Models.Device>

<div class="table-responsive">
    <table class="table table-hover table-striped mb-0">
        <thead class="table-light">
            <tr>
                <th scope="col" class="text-center" style="width: 60px;">ID</th>
                <th scope="col">Name</th>
                <th scope="col">Manufacturer</th>
                <th scope="col">Serial Number</th>
                <th scope="col">Purchase Date</th>
                <th scope="col" class="text-center" style="width: 180px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || !Model.Any())
            {
                <tr>
                    <td colspan="6" class="text-center text-muted py-4">
                        No devices found. Use the search box or add a new device.
                    </td>
                </tr>
            }
            else
            {
                foreach (var device in Model)
                {
                    <tr>
                        <td class="text-center align-middle">
                            <span class="badge bg-secondary">@device.Id</span>
                        </td>
                        <td class="align-middle">
                            <strong>@device.Name</strong>
                        </td>
                        <td class="align-middle">@device.Manufacturer</td>
                        <td class="align-middle"><code>@device.SerialNumber</code></td>
                        <td class="align-middle">@device.PurchaseDate?.ToString("dd.MM.yyyy")</td>
                        <td class="text-center align-middle">
                            <a asp-action="Details" asp-controller="Device" asp-route-id="@device.Id" class="btn btn-sm btn-outline-info me-1">Details</a>
                            <a asp-action="Edit" asp-controller="Device" asp-route-id="@device.Id" class="btn btn-sm btn-outline-primary me-1">Edit</a>
                            <a asp-action="Delete" asp-controller="Device" asp-route-id="@device.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
