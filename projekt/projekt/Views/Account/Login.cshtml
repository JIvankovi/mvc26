@model LoginViewModel
@{
    ViewData["Title"] = "Sign in";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h1 class="h3 mb-3">Sign in</h1>
                <form asp-action="Login" asp-route-returnUrl="@returnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                    <div class="form-check mb-3">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label"></label>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Sign in</button>
                </form>
                <div class="mt-4">
                    <div class="text-uppercase text-muted small mb-2">Use another service</div>
                    <div class="d-grid gap-2">
                        @if (ViewData["GoogleLoginEnabled"] as bool? == true)
                        {
                            <form asp-action="ExternalLogin" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="provider" value="Google" />
                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                <button type="submit" class="btn btn-outline-danger w-100">Continue with Google</button>
                            </form>
                        }
                        else
                        {
                            <button type="button" class="btn btn-outline-danger w-100" disabled>Continue with Google</button>
                        }

                        @if (ViewData["MicrosoftLoginEnabled"] as bool? == true)
                        {
                            <form asp-action="ExternalLogin" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="provider" value="Microsoft" />
                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                <button type="submit" class="btn btn-outline-primary w-100">Continue with Microsoft</button>
                            </form>
                        }
                        else
                        {
                            <button type="button" class="btn btn-outline-primary w-100" disabled>Continue with Microsoft</button>
                        }
                    </div>
                    @if ((ViewData["GoogleLoginEnabled"] as bool? != true) && (ViewData["MicrosoftLoginEnabled"] as bool? != true))
                    {
                        <p class="text-muted small mt-2 mb-0">Configure Google or Microsoft client credentials to enable these sign-in options.</p>
                    }
                </div>
                <p class="mt-3 mb-0">
                    New here? <a asp-action="Register">Create an account</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}