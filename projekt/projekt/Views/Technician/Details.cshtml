@model projekt.Models.Technician

@{
    ViewData["Title"] = "Technician Details";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Header Section -->
            <div class="d-flex align-items-center mb-4">
                <h1 class="mb-0">Technician Details</h1>
            </div>

            <!-- Technician Card -->
            <div class="card shadow-lg border-0 mb-4">
                <div class="card-header bg-success text-white py-4">
                    <h2 class="mb-0">@Model.Name</h2>
                </div>
                <div class="card-body p-4">
                    <!-- Details Grid -->
                    <div class="row mb-4">
                        <div class="col-md-6 mb-3">
                            <h6 class="text-muted text-uppercase fw-bold mb-2">Technician ID</h6>
                            <p class="fs-5">@Model.Id</p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <h6 class="text-muted text-uppercase fw-bold mb-2">Years of Experience</h6>
                            <p class="fs-5">
                                <span class="badge bg-info">@Model.YearsOfExperience years</span>
                            </p>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6 mb-3">
                            <h6 class="text-muted text-uppercase fw-bold mb-2">Email</h6>
                            <p class="fs-5">
                                <a href="mailto:@Model.Email">@Model.Email</a>
                            </p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <h6 class="text-muted text-uppercase fw-bold mb-2">Phone Number</h6>
                            <p class="fs-5">
                                <a href="tel:@Model.PhoneNumber">@Model.PhoneNumber</a>
                            </p>
                        </div>
                    </div>

                    <!-- Certification Section -->
                    <div class="row mb-4">
                        <div class="col-12 mb-3">
                            <h6 class="text-muted text-uppercase fw-bold mb-2">Certification</h6>
                            <p class="fs-5">
                                <span class="badge bg-warning text-dark">@Model.Certification</span>
                            </p>
                        </div>
                    </div>

                    <!-- Info Alert -->
                    <div class="alert alert-info mt-4" role="alert">
                        <strong>Profile Status:</strong> Active and certified technician available for assignments.
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="d-flex gap-2 justify-content-center">
                <a href="/Technician/Index" class="btn btn-secondary btn-lg px-4">
                    <i class="bi bi-arrow-left"></i> Back to Technicians
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .card-header {
        border-top-left-radius: 0.375rem;
        border-top-right-radius: 0.375rem;
    }

    .card {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }

    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 1.5rem 3rem rgba(0, 0, 0, 0.2) !important;
    }

    .badge {
        font-size: 0.95rem;
        padding: 0.5rem 0.75rem;
    }

    a {
        color: #0d6efd;
        text-decoration: none;
    }

    a:hover {
        text-decoration: underline;
    }
</style>
