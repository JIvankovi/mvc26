@model List<projekt.Models.Technician>

@{
    ViewData["Title"] = "Technicians";
}

<div class="container mt-5">
    <div class="row mb-4 align-items-end">
        <div class="col-md-6">
            <h1 class="display-5">Technicians</h1>
            <p class="text-muted">Search, review and manage technicians using an AJAX-enabled list view.</p>
        </div>
        <div class="col-md-6 text-end">
            <a asp-action="Create" asp-controller="Technician" class="btn btn-primary">Add Technician</a>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-8">
            <div class="input-group shadow-sm">
                <span class="input-group-text">Search</span>
                <input id="technician-search" class="form-control" placeholder="Search name, email or certification" />
                <button id="technician-search-clear" type="button" class="btn btn-outline-secondary">Clear</button>
            </div>
        </div>
    </div>

    <div id="technician-table-container">
        @await Html.PartialAsync("_TechnicianTable", Model)
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            lab4.initSearch("#technician-search", "#technician-table-container", "@Url.Action("Search", "Technician")");
        });
    </script>
}
