@model List<projekt.Models.Technician>

@{
    ViewData["Title"] = "Technicians";
}

<div class="container mt-5">
    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="display-4">
                <span class="badge bg-primary">Technicians</span>
            </h1>
            <p class="text-muted">Manage and view all laboratory technicians</p>
        </div>
        <div class="col-md-4 text-end">
            
        </div>
    </div>

    <!-- Content Section -->
    @if (Model != null && Model.Count > 0)
    {
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Registered Technicians</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-light">
                            <tr>
                                <th scope="col" class="text-center" style="width: 60px;">ID</th>
                                <th scope="col">Name</th>
                                <th scope="col">Email</th>
                                <th scope="col">Phone</th>
                                <th scope="col">Certification</th>
                                <th scope="col" class="text-center">Years of Experience</th>
                                <th scope="col" class="text-center" style="width: 120px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var technician in Model)
                            {
                                <tr>
                                    <td class="text-center">
                                        <span class="badge bg-secondary">@technician.Id</span>
                                    </td>
                                    <td>
                                        <strong>@technician.Name</strong>
                                    </td>
                                    <td>
                                        <a href="mailto:@technician.Email">@technician.Email</a>
                                    </td>
                                    <td>
                                        <a href="tel:@technician.PhoneNumber">@technician.PhoneNumber</a>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(technician.Certification))
                                        {
                                            <span class="badge bg-info">@technician.Certification</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-warning">@technician.YearsOfExperience</span>
                                    </td>
                                    <td class="text-center">
                                        <a href="@Url.Action("Details", "Technician", new { id = technician.Id })" class="btn btn-sm btn-info">
                                            <i class="bi bi-eye"></i> Details
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <strong>No technicians found!</strong> There are currently no technicians in the database.
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
</div>

<style>
    .card {
        border: none;
        border-radius: 0.5rem;
    }

    .table th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
    }

    .table tbody tr {
        transition: background-color 0.15s ease-in-out;
    }

    .btn-sm {
        padding: 0.375rem 0.75rem;
        font-size: 0.875rem;
        border-radius: 0.25rem;
    }

    .badge {
        font-size: 0.85rem;
        padding: 0.35em 0.65em;
        border-radius: 0.25rem;
    }

    a[href^="mailto:"],
    a[href^="tel:"] {
        color: #0d6efd;
        text-decoration: none;
    }

    a[href^="mailto:"]:hover,
    a[href^="tel:"]:hover {
        text-decoration: underline;
    }
</style>
