@model projekt.Models.Technician

@{
    ViewData["Title"] = "Delete Technician";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="display-5">Delete Technician</h1>
            <p class="text-muted">Confirm removal of this technician from the system.</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Index" asp-controller="Technician" class="btn btn-outline-secondary">Back to Technicians</a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <dl class="row">
                <dt class="col-sm-4">ID</dt>
                <dd class="col-sm-8">@Model.Id</dd>
                <dt class="col-sm-4">Name</dt>
                <dd class="col-sm-8">@Model.Name</dd>
                <dt class="col-sm-4">Email</dt>
                <dd class="col-sm-8">@Model.Email</dd>
                <dt class="col-sm-4">Certification</dt>
                <dd class="col-sm-8">@Model.Certification</dd>
                <dt class="col-sm-4">Experience</dt>
                <dd class="col-sm-8">@Model.YearsOfExperience years</dd>
            </dl>

            <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                <button type="submit" class="btn btn-danger">Delete Technician</button>
                <a asp-action="Index" asp-controller="Technician" class="btn btn-secondary ms-2">Cancel</a>
            </form>
        </div>
    </div>
</div>
