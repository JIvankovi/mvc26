@model List<projekt.Models.Technician>

<div class="table-responsive">
    <table class="table table-hover table-striped mb-0">
        <thead class="table-light">
            <tr>
                <th scope="col" class="text-center" style="width: 60px;">ID</th>
                <th scope="col">Name</th>
                <th scope="col">Email</th>
                <th scope="col">Certification</th>
                <th scope="col">Experience</th>
                <th scope="col" class="text-center" style="width: 180px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || !Model.Any())
            {
                <tr>
                    <td colspan="6" class="text-center text-muted py-4">No technicians found. Add one to continue.</td>
                </tr>
            }
            else
            {
                foreach (var technician in Model)
                {
                    <tr>
                        <td class="text-center align-middle"><span class="badge bg-secondary">@technician.Id</span></td>
                        <td class="align-middle">@technician.Name</td>
                        <td class="align-middle">@technician.Email</td>
                        <td class="align-middle">@technician.Certification</td>
                        <td class="align-middle">@technician.YearsOfExperience years</td>
                        <td class="text-center align-middle">
                            <a asp-action="Details" asp-controller="Technician" asp-route-id="@technician.Id" class="btn btn-sm btn-outline-info me-1">Details</a>
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <a asp-action="Edit" asp-controller="Technician" asp-route-id="@technician.Id" class="btn btn-sm btn-outline-primary me-1">Edit</a>
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Delete" asp-controller="Technician" asp-route-id="@technician.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                                }
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
