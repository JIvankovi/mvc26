@{
    ViewData["Title"] = "Metrology Instrumentation Dashboard";
}

<div class="page-container">
    <!-- Header -->
    <div class="mb-5">
        <h1 class="page-title">Metrology Instrumentation Dashboard</h1>
        <p class="text-muted">Laboratory Statistics, Technician Performance & Calibration History</p>
    </div>

    <!-- Laboratory Statistics Section -->
    <section class="mb-5">
        <div class="section-header mb-4">
            <h2 class="section-title">Laboratory Statistics by Building</h2>
            <div class="section-divider"></div>
        </div>
        <div class="row g-3">
            @foreach (var lab in ViewBag.LaboratoryStats)
            {
                <div class="col-12 col-md-6 col-lg-12">
                    <div class="card stat-card border-0 h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h5 class="card-title mb-1">Building @lab.Building</h5>
                                    <p class="text-muted small mb-0">@lab.LaboratoryName</p>
                                </div>
                                <span class="badge bg-primary rounded-pill fs-6">@lab.TotalDevices Devices</span>
                            </div>
                            
                            <div class="device-grid">
                                <div class="device-item">
                                    <span class="device-label">Oscilloscopes</span>
                                    <span class="device-count">@lab.Oscilloscopes</span>
                                </div>
                                <div class="device-item">
                                    <span class="device-label">Voltmeters</span>
                                    <span class="device-count">@lab.Voltmeters</span>
                                </div>
                                <div class="device-item">
                                    <span class="device-label">Barometers</span>
                                    <span class="device-count">@lab.Barometers</span>
                                </div>
                                <div class="device-item">
                                    <span class="device-label">Thermometers</span>
                                    <span class="device-count">@lab.Thermometers</span>
                                </div>
                                <div class="device-item">
                                    <span class="device-label">Hygrometers</span>
                                    <span class="device-count">@lab.Hygrometers</span>
                                </div>
                                <div class="device-item">
                                    <span class="device-label">Anemometers</span>
                                    <span class="device-count">@lab.Anemometers</span>
                                </div>
                                <div class="device-item">
                                    <span class="device-label">Spectrophotometers</span>
                                    <span class="device-count">@lab.Spectrophotometers</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>

    <!-- Technician Performance Section -->
    <section class="mb-5">
        <div class="section-header mb-4">
            <h2 class="section-title">Technician Performance</h2>
            <div class="section-divider"></div>
        </div>
        <div class="card border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0 modern-table">
                        <thead>
                            <tr>
                                <th>Technician Name</th>
                                <th>Certification</th>
                                <th>Experience</th>
                                <th class="text-center">Calibrations</th>
                                <th class="text-center">Success Rate</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tech in ViewBag.TechnicianStats)
                            {
                                <tr>
                                    <td class="fw-5">@tech.Technician.Name</td>
                                    <td><span class="badge bg-info bg-opacity-10 text-info">@tech.Technician.Certification</span></td>
                                    <td>@tech.Technician.YearsOfExperience years</td>
                                    <td class="text-center"><span class="badge bg-secondary">@tech.CalibrationCount</span></td>
                                    <td class="text-center">
                                        <span class="badge bg-success">@tech.SuccessRate.ToString("F1")%</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>

    <!-- Recent Calibrations Section -->
    <section class="mb-5">
        <div class="section-header mb-4">
            <h2 class="section-title">Recent Calibration History</h2>
            <div class="section-divider"></div>
        </div>
        <div class="card border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0 modern-table">
                        <thead>
                            <tr>
                                <th>Date & Time</th>
                                <th>Technician</th>
                                <th>Standard</th>
                                <th>Deviation</th>
                                <th class="text-center">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cal in ViewBag.RecentCalibrations)
                            {
                                <tr>
                                    <td>@cal.CalibrationDateTime.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>@cal.Technician.Name</td>
                                    <td>@cal.CalibrationStandard</td>
                                    <td>@cal.MeasuredDeviation</td>
                                    <td class="text-center">
                                        @if (cal.PassedCalibration)
                                        {
                                            <span class="badge bg-success">Passed</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Failed</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>
</div>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Devices by Measurement Type -->
    <div class="card mb-4">
        <div class="card-header bg-secondary text-white">
            <h3><i class="bi bi-pie-chart"></i> Devices Grouped by Measurement Type</h3>
        </div>
        <div class="card-body">
            <div class="row">
                @foreach (var group in ViewBag.DevicesByType)
                {
                    <div class="col-md-6 mb-3">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="card-title">@group.Type</h5>
                                <p class="card-text">
                                    <span class="badge bg-primary fs-5">@group.Count device(s)</span>
                                </p>
                                <ul class="list-unstyled">
                                    @foreach (var device in group.Devices)
                                    {
                                        <li><i class="bi bi-check-circle text-success"></i> @device.Name (@device.Manufacturer)</li>
                                    }
                                </ul>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }
    .card-header h3 {
        margin: 0;
        font-size: 1.5rem;
    }
</style>
