@model projekt.Models.Calibration

@{
    ViewData["Title"] = "Delete Calibration";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="display-5">Delete Calibration</h1>
            <p class="text-muted">Confirm deletion of this calibration record.</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Index" asp-controller="Calibration" class="btn btn-outline-secondary">Back to Calibrations</a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <dl class="row">
                <dt class="col-sm-4">ID</dt>
                <dd class="col-sm-8">@Model.Id</dd>
                <dt class="col-sm-4">Device</dt>
                <dd class="col-sm-8">@Model.Device?.Name ?? "Unknown"</dd>
                <dt class="col-sm-4">Technician</dt>
                <dd class="col-sm-8">@Model.Technician?.Name ?? "N/A"</dd>
                <dt class="col-sm-4">Calibration Date</dt>
                <dd class="col-sm-8">@Model.CalibrationDateTime.ToString("dd.MM.yyyy HH:mm")</dd>
                <dt class="col-sm-4">Next Due</dt>
                <dd class="col-sm-8">@Model.NextCalibrationDue?.ToString("dd.MM.yyyy") ?? "Not set"</dd>
            </dl>

            <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                <button type="submit" class="btn btn-danger">Delete Calibration</button>
                <a asp-action="Index" asp-controller="Calibration" class="btn btn-secondary ms-2">Cancel</a>
            </form>
        </div>
    </div>
</div>
