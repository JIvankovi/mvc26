@model projekt.Models.Calibration

@{
    ViewData["Title"] = "Calibration Details";
}

<div class="container mt-5">
    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="display-5">
                <span class="badge bg-primary">Calibration Details</span>
            </h1>
            <p class="text-muted">ID: <strong>@Model.Id</strong></p>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Index", "Calibration")" class="btn btn-outline-secondary btn-lg">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>
    </div>

    <!-- Main Content -->
    <div class="row">
        <!-- Left Column -->
        <div class="col-lg-6 mb-4">
            <!-- Basic Information Card -->
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-gradient text-white" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                    <h5 class="mb-0">
                        <i class="bi bi-info-circle"></i> Basic Information
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-sm-5">
                            <label class="form-label text-muted">
                                <strong>Calibration ID</strong>
                            </label>
                        </div>
                        <div class="col-sm-7">
                            <span class="badge bg-secondary fs-6">@Model.Id</span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-5">
                            <label class="form-label text-muted">
                                <strong>Technician ID</strong>
                            </label>
                        </div>
                        <div class="col-sm-7">
                            <span>@Model.Technician.Id</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column -->
        <div class="col-lg-6 mb-4">
            <!-- Dates Card -->
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-gradient text-white" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                    <h5 class="mb-0">
                        <i class="bi bi-calendar3"></i> Important Dates
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-sm-5">
                            <label class="form-label text-muted">
                                <strong>Calibration Date</strong>
                            </label>
                        </div>
                        <div class="col-sm-7">
                            <span class="fw-semibold">
                                @Model.CalibrationDateTime.ToShortDateString()
                            </span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-5">
                            <label class="form-label text-muted">
                                <strong>Due Date</strong>
                            </label>
                        </div>
                        <div class="col-sm-7">
                            <span class="fw-semibold">
                                @Model.NextCalibrationDue.ToShortDateString()
                            </span>
                        </div>
                    </div>

                    <!-- Days Until Due -->
                    @{
                        var daysUntilDue = (Model.NextCalibrationDue - DateTime.Now).Days;
                        var badgeClass = daysUntilDue > 30 ? "bg-success" : daysUntilDue > 7 ? "bg-warning" : "bg-danger";
                    }
                    <div class="alert alert-light border mt-3">
                        <small class="text-muted">Days until next calibration:</small>
                        <br />
                        <span class="badge @badgeClass fs-6">@daysUntilDue days</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Result Card -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-gradient text-white" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
                    <h5 class="mb-0">
                        <i class="bi bi-check-circle"></i> Calibration Result
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-md-6">
                            <label class="form-label text-muted mb-2">
                                <strong>Result Status</strong>
                            </label>
                        </div>
                        <div class="col-md-6">
                            @if (Model.PassedCalibration)
                            {
                                <span class="badge bg-success fs-5 px-3 py-2">
                                    <i class="bi bi-check-circle"></i> PASSED
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger fs-5 px-3 py-2">
                                    <i class="bi bi-x-circle"></i> FAILED
                                </span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="row mb-5">
        <div class="col-12">
            <div class="d-flex gap-2 justify-content-start">
                <div>
                    <a href="@Url.Action("Index", "Calibration")" class="btn btn-outline-secondary btn-lg">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        transition: transform 0.2s, box-shadow 0.2s;
    }
    
    .card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15) !important;
    }
    
    .badge {
        font-weight: 500;
        letter-spacing: 0.5px;
    }
    
    .form-label {
        font-size: 0.9rem;
        letter-spacing: 0.3px;
    }
</style>
