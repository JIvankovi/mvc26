@model List<projekt.Models.Calibration>

@{
    ViewData["Title"] = "Calibrations";
}

<div class="container mt-5">
    <div class="row mb-4 align-items-end">
        <div class="col-md-6">
            <h1 class="display-5">Calibrations</h1>
            <p class="text-muted">Review calibration history and search across related devices and technicians.</p>
        </div>
        <div class="col-md-6 text-end">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-action="Create" asp-controller="Calibration" class="btn btn-primary">Add Calibration</a>
            }
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-8">
            <div class="input-group shadow-sm">
                <span class="input-group-text">Search</span>
                <input id="calibration-search" class="form-control" placeholder="Search device, technician or standard" />
                <button id="calibration-search-clear" type="button" class="btn btn-outline-secondary">Clear</button>
            </div>
        </div>
    </div>

    <div id="calibration-table-container">
        @await Html.PartialAsync("_CalibrationTable", Model)
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            lab4.initSearch("#calibration-search", "#calibration-table-container", "@Url.Action("Search", "Calibration")");
        });
    </script>
}
