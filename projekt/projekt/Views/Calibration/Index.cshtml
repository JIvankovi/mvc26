@model List<projekt.Models.Calibration>

@{
    ViewData["Title"] = "Calibrations";
}

<div class="container mt-5">
    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="display-4">
                <span class="badge bg-primary">Calibrations</span>
            </h1>
            <p class="text-muted">Manage and view all device calibrations</p>
        </div>
        <div class="col-md-4 text-end">
            
        </div>
    </div>

    <!-- Content Section -->
    @if (Model != null && Model.Count > 0)
    {
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Registered Calibrations</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-light">
                            <tr>
                                <th scope="col" class="text-center" style="width: 60px;">ID</th>
                                <th scope="col">Technician</th>
                                <th scope="col">Calibration Date</th>
                                <th scope="col">Calibration Standard</th>
                                <th scope="col" class="text-center">Deviation</th>
                                <th scope="col" class="text-center">Status</th>
                                <th scope="col">Next Due</th>
                                <th scope="col" class="text-center" style="width: 120px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var calibration in Model)
                            {
                                <tr>
                                    <td class="text-center">
                                        <span class="badge bg-secondary">@calibration.Id</span>
                                    </td>
                                    <td>
                                        <strong>@calibration.Technician?.Name ?? "N/A"</strong>
                                    </td>
                                    <td>
                                        @calibration.CalibrationDateTime.ToShortDateString()
                                    </td>
                                    <td>
                                        <code>@calibration.CalibrationStandard</code>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-info">@calibration.MeasuredDeviation</span>
                                    </td>
                                    <td class="text-center">
                                        @if (calibration.PassedCalibration)
                                        {
                                            <span class="badge bg-success">
                                                <i class="bi bi-check-circle"></i> Passed
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">
                                                <i class="bi bi-x-circle"></i> Failed
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        @calibration.NextCalibrationDue.ToShortDateString()
                                    </td>
                                    <td class="text-center">
                                        <a href="@Url.Action("Details", "Calibration", new { id = calibration.Id })" class="btn btn-sm btn-info">
                                            <i class="bi bi-eye"></i> Details
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <strong>No calibrations found!</strong> There are currently no calibrations in the database.
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
</div>

<style>
    .card {
        border: none;
        border-radius: 0.5rem;
    }

    .table th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
    }

    .table tbody tr {
        transition: background-color 0.15s ease-in-out;
    }

    .btn-sm {
        padding: 0.375rem 0.75rem;
    }
</style>
