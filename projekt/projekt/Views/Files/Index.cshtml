@{
    ViewData["Title"] = "Files";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4 p-md-5">
                <div class="mb-4">
                    <h1 class="h3 mb-2">Files</h1>
                    <p class="text-muted mb-0">Drop a file below to upload it to the server. Uploaded files are stored locally in <span class="fw-semibold">wwwroot/uploads</span> and tracked in the database.</p>
                </div>

                <form asp-action="Upload" asp-controller="Files" method="post" class="dropzone border rounded-3 bg-light p-4" id="file-dropzone" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="dz-message needsclick text-center py-5">
                        <div class="display-6 mb-2">Drop files here</div>
                        <p class="mb-0 text-muted">or click to browse your computer</p>
                    </div>
                </form>

                <div class="mt-3">
                    <div class="small text-muted mb-1" id="upload-status">Ready to upload.</div>
                    <div class="progress" style="height: 6px;">
                        <div id="upload-progress-bar" class="progress-bar" role="progressbar" style="width: 0%;"></div>
                    </div>
                </div>

                <div class="mt-5">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="h5 mb-0">Uploaded Files</h2>
                        <button type="button" class="btn btn-sm btn-outline-secondary" id="refresh-files">Refresh</button>
                    </div>
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>File</th>
                                    <th>Size</th>
                                    <th>Uploaded</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody id="files-list">
                                <tr><td colspan="4" class="text-muted">Loading files...</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/dropzone@5.9.3/dist/min/dropzone.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/dropzone@5.9.3/dist/min/dropzone.min.js"></script>
    <script>
        Dropzone.autoDiscover = false;

        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        const statusElement = document.getElementById('upload-status');
        const progressBar = document.getElementById('upload-progress-bar');
        const filesList = document.getElementById('files-list');
        const refreshButton = document.getElementById('refresh-files');

        const formatBytes = (bytes) => {
            if (!bytes) {
                return '0 B';
            }

            const units = ['B', 'KB', 'MB', 'GB'];
            let size = bytes;
            let unitIndex = 0;

            while (size >= 1024 && unitIndex < units.length - 1) {
                size /= 1024;
                unitIndex += 1;
            }

            return `${size.toFixed(size >= 10 || unitIndex === 0 ? 0 : 1)} ${units[unitIndex]}`;
        };

        const escapeHtml = (value) => value
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');

        const loadFiles = async () => {
            const response = await fetch('@Url.Action("List", "Files")', { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
            if (!response.ok) {
                filesList.innerHTML = '<tr><td colspan="4" class="text-danger">Unable to load files.</td></tr>';
                return;
            }

            const files = await response.json();
            if (!files.length) {
                filesList.innerHTML = '<tr><td colspan="4" class="text-muted">No files uploaded yet.</td></tr>';
                return;
            }

            filesList.innerHTML = files.map(file => `
                <tr data-file-id="${file.id}">
                    <td>
                        <div class="fw-semibold">${escapeHtml(file.originalFileName)}</div>
                        <div class="text-muted small">${escapeHtml(file.relativePath)}</div>
                    </td>
                    <td>${formatBytes(file.sizeBytes)}</td>
                    <td>${escapeHtml(file.uploadedAtUtc)}</td>
                    <td class="text-end">
                        <a href="${file.downloadUrl}" class="btn btn-sm btn-outline-secondary me-2" target="_blank" rel="noreferrer">Open</a>
                        <button type="button" class="btn btn-sm btn-outline-danger delete-file" data-file-id="${file.id}">Delete</button>
                    </td>
                </tr>
            `).join('');
        };

        const deleteFile = async (fileId) => {
            const response = await fetch('@Url.Action("Delete", "Files")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                    'RequestVerificationToken': token ?? ''
                },
                body: new URLSearchParams({ id: fileId })
            });

            if (!response.ok) {
                const message = await response.text();
                alert(`Delete failed: ${message}`);
                return;
            }

            await loadFiles();
        };

        const dropzone = new Dropzone('#file-dropzone', {
            url: '@Url.Action("Upload", "Files")',
            paramName: 'file',
            maxFilesize: 50,
            timeout: 0,
            headers: token ? { 'RequestVerificationToken': token } : {},
            init: function () {
                this.on('sending', function () {
                    statusElement.textContent = 'Uploading...';
                    progressBar.style.width = '0%';
                    progressBar.classList.remove('bg-success');
                });

                this.on('uploadprogress', function (_file, progress) {
                    progressBar.style.width = `${progress}%`;
                    statusElement.textContent = `Uploading... ${Math.round(progress)}%`;
                });

                this.on('success', function (_file, response) {
                    progressBar.style.width = '100%';
                    progressBar.classList.add('bg-success');
                    statusElement.textContent = `Uploaded ${response.fileName}`;
                    loadFiles();
                });

                this.on('error', function (_file, message) {
                    statusElement.textContent = 'Upload failed.';
                    console.error(message);
                });
            },
            success: function (file, response) {
                file.previewElement?.classList.add('dz-success');
            }
        });

        refreshButton.addEventListener('click', loadFiles);

        filesList.addEventListener('click', async (event) => {
            const target = event.target;
            if (!(target instanceof HTMLElement)) {
                return;
            }

            if (target.classList.contains('delete-file')) {
                const fileId = target.getAttribute('data-file-id');
                if (!fileId) {
                    return;
                }

                if (!confirm('Delete this file from disk and the database?')) {
                    return;
                }

                await deleteFile(fileId);
            }
        });

        loadFiles();
    </script>
}