@model List<projekt.Models.Laboratory>

@{
    ViewData["Title"] = "Laboratories";
}

<div class="container mt-5">
    <div class="row mb-4 align-items-end">
        <div class="col-md-6">
            <h1 class="display-5">Laboratories</h1>
            <p class="text-muted">Search, review and manage laboratory records using AJAX.</p>
        </div>
        <div class="col-md-6 text-end">
            <a asp-action="Create" asp-controller="Laboratory" class="btn btn-primary">Add Laboratory</a>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-8">
            <div class="input-group shadow-sm">
                <span class="input-group-text">Search</span>
                <input id="laboratory-search" class="form-control" placeholder="Search by name, location or code" />
                <button id="laboratory-search-clear" type="button" class="btn btn-outline-secondary">Clear</button>
            </div>
        </div>
    </div>

    <div id="laboratory-table-container">
        @await Html.PartialAsync("_LaboratoryTable", Model)
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            lab4.initSearch("#laboratory-search", "#laboratory-table-container", "@Url.Action("Search", "Laboratory")");
        });
    </script>
}
