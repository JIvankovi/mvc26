@model List<projekt.Models.Laboratory>

@{
    ViewData["Title"] = "Laboratories";
}

<div class="container-fluid mt-5">
    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="display-5 fw-bold text-primary">
                <i class="bi bi-building"></i> Laboratories
            </h1>
            <p class="text-muted">Manage and view all laboratory information</p>
        </div>
        <div class="col-md-4 d-flex align-items-center justify-content-end">
            
        </div>
    </div>

    <!-- Content Section -->
    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <i class="bi bi-info-circle"></i>
            <strong>No laboratories found.</strong> Get started by creating your first laboratory.
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    else
    {
        <!-- Table Section -->
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-3">
                <h5 class="card-title mb-0 fw-bold">Laboratory Directory</h5>
            </div>
            <div class="card-body p-0">
                <!-- Desktop Table View -->
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4 fw-bold text-muted text-uppercase small">ID</th>
                                <th class="fw-bold text-muted text-uppercase small">Name</th>
                                <th class="fw-bold text-muted text-uppercase small">Location</th>
                                <th class="fw-bold text-muted text-uppercase small">Contact Person</th>
                                <th class="text-end pe-4 fw-bold text-muted text-uppercase small">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var laboratory in Model)
                            {
                                <tr class="border-bottom">
                                    <td class="ps-4 fw-bold text-primary">
                                        <span class="badge bg-primary bg-opacity-10 text-primary">@laboratory.Id</span>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-sm me-3 bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center"
                                                 style="width: 40px; height: 40px;">
                                                <i class="bi bi-building text-primary"></i>
                                            </div>
                                            <span class="fw-semibold">@laboratory.Name</span>
                                        </div>
                                    </td>
                                    <td>
                                        <i class="bi bi-geo-alt-fill text-danger me-2"></i>@laboratory.Location
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-person-circle text-success me-2"></i>
                                            @(string.IsNullOrEmpty(laboratory.ResponsiblePerson) ? "N/A" : laboratory.ResponsiblePerson)
                                        </div>
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-action="Details" asp-route-id="@laboratory.Id" 
                                               class="btn btn-outline-primary" title="View Details">
                                                <i class="bi bi-eye"></i> Details
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <!-- Footer with Pagination Info -->
            <div class="card-footer bg-light text-muted small text-center py-3 border-top-0">
                <i class="bi bi-info-circle me-1"></i>Showing @Model.Count laboratory item@(Model.Count != 1 ? "s" : "")
            </div>
        </div>
    }
</div>

<!-- Custom Styling -->
<style>
    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
        transition: background-color 0.15s ease-in-out;
    }

    .btn-group-sm .btn {
        padding: 0.4rem 0.65rem;
        font-size: 0.875rem;
    }

    .card {
        transition: box-shadow 0.3s ease-in-out;
    }

    .card:hover {
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }

    .badge {
        font-size: 0.75rem;
        padding: 0.35rem 0.55rem;
    }

    h1.display-5 {
        font-size: 2.5rem;
    }
</style>
