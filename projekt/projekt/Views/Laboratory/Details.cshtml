@model projekt.Models.Laboratory

@{
    ViewData["Title"] = $"Laboratory - {Model.Name}";
}

<div class="container-fluid mt-5">
    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="display-5 fw-bold text-primary">
                <i class="bi bi-building"></i> Laboratory Details
            </h1>
            <p class="text-muted">View complete information about this laboratory</p>
        </div>
        <div class="col-md-4 d-flex align-items-center justify-content-end">
            <a href="/Laboratory/Index" class="btn btn-secondary btn-lg rounded-pill">
                <i class="bi bi-arrow-left"></i> Back to Laboratories
            </a>
        </div>
    </div>

    <!-- Details Card Section -->
    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <!-- Card Header -->
                <div class="card-header bg-primary text-white p-4">
                    <h4 class="mb-0 fw-bold">@Model.Name</h4>
                </div>

                <!-- Card Body -->
                <div class="card-body p-4">
                    <!-- Laboratory ID -->
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <div class="detail-item">
                                <label class="form-label fw-bold text-secondary">Laboratory ID</label>
                                <p class="fs-5 text-dark">@Model.Id</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="detail-item">
                                <label class="form-label fw-bold text-secondary">Name</label>
                                <p class="fs-5 text-dark">@Model.Name</p>
                            </div>
                        </div>
                    </div>

                    <!-- Location and Building Code -->
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <div class="detail-item">
                                <label class="form-label fw-bold text-secondary">
                                    <i class="bi bi-geo-alt"></i> Location
                                </label>
                                <p class="fs-5 text-dark">@Model.Location</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="detail-item">
                                <label class="form-label fw-bold text-secondary">Building Code</label>
                                <p class="fs-5 text-dark">@Model.BuildingCode</p>
                            </div>
                        </div>
                    </div>

                    <!-- Room Number and Responsible Person -->
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <div class="detail-item">
                                <label class="form-label fw-bold text-secondary">Room Number</label>
                                <p class="fs-5 text-dark">@Model.RoomNumber</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="detail-item">
                                <label class="form-label fw-bold text-secondary">
                                    <i class="bi bi-person"></i> Responsible Person
                                </label>
                                <p class="fs-5 text-dark">@Model.ResponsiblePerson</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Card Footer -->
                <div class="card-footer bg-light p-4 border-top">
                    <div class="d-flex gap-2">
                        <a href="/Laboratory/Index" class="btn btn-secondary rounded-pill">
                            <i class="bi bi-arrow-left"></i> Back
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Side Information Panel -->
        <div class="col-lg-4">
            <div class="card shadow-lg border-0 rounded-4 bg-info bg-opacity-10 mb-3">
                <div class="card-body p-4">
                    <h5 class="card-title fw-bold text-info mb-3">
                        <i class="bi bi-info-circle"></i> Quick Info
                    </h5>
                    <div class="list-group list-group-flush">
                        <div class="list-group-item bg-transparent border-0 px-0 py-2">
                            <small class="text-muted">Total Devices</small>
                            <p class="fw-bold fs-5">@(Model.DeviceLocations?.Count ?? 0)</p>
                        </div>
                        <div class="list-group-item bg-transparent border-0 px-0 py-2">
                            <small class="text-muted">Status</small>
                            <p class="fw-bold fs-5"><span class="badge bg-success">Active</span></p>
                        </div>
                        <div class="list-group-item bg-transparent border-0 px-0 py-2">
                            <small class="text-muted">Last Updated</small>
                            <p class="fw-bold fs-5">Today</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Devices Section -->
            @if (Model.DeviceLocations != null && Model.DeviceLocations.Count > 0)
            {
                <div class="card shadow-lg border-0 rounded-4">
                    <div class="card-header bg-success text-white p-4">
                        <h5 class="mb-0 fw-bold">
                            <i class="bi bi-motherboard"></i> Devices
                        </h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="list-group list-group-flush">
                            @foreach (var deviceLocation in Model.DeviceLocations)
                            {
                                <div class="list-group-item px-0 py-2 border-0">
                                    <small class="text-muted">Device @deviceLocation.Device.Id</small>
                                    <p class="fw-bold mb-0">@deviceLocation.Device.Name</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .detail-item {
        padding: 0.5rem 0;
    }

    .card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.15) !important;
    }

    .rounded-4 {
        border-radius: 1rem !important;
    }

    .btn-lg.rounded-pill {
        padding: 0.75rem 1.5rem;
    }
</style>
