@model List<projekt.Models.Laboratory>

<div class="table-responsive">
    <table class="table table-hover table-striped mb-0">
        <thead class="table-light">
            <tr>
                <th scope="col" class="text-center" style="width: 60px;">ID</th>
                <th scope="col">Name</th>
                <th scope="col">Location</th>
                <th scope="col">Building Code</th>
                <th scope="col">Room</th>
                <th scope="col">Responsible</th>
                <th scope="col" class="text-center" style="width: 200px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || !Model.Any())
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">No laboratories found. Add one to begin.</td>
                </tr>
            }
            else
            {
                foreach (var lab in Model)
                {
                    <tr>
                        <td class="text-center align-middle"><span class="badge bg-secondary">@lab.Id</span></td>
                        <td class="align-middle">@lab.Name</td>
                        <td class="align-middle">@lab.Location</td>
                        <td class="align-middle">@lab.BuildingCode</td>
                        <td class="align-middle">@lab.RoomNumber</td>
                        <td class="align-middle">@lab.ResponsiblePerson</td>
                        <td class="text-center align-middle">
                            <a asp-action="Details" asp-controller="Laboratory" asp-route-id="@lab.Id" class="btn btn-sm btn-outline-info me-1">Details</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-controller="Laboratory" asp-route-id="@lab.Id" class="btn btn-sm btn-outline-primary me-1">Edit</a>
                                <a asp-action="Delete" asp-controller="Laboratory" asp-route-id="@lab.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
