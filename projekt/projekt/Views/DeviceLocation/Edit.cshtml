@model projekt.ViewModels.DeviceLocationFormViewModel

@{
    ViewData["Title"] = "Edit Device Location";
}

<div class="container mt-5">
    <div class="row mb-4 align-items-end">
        <div class="col-md-8">
            <h1 class="display-5">Edit Device Location</h1>
            <p class="text-muted">Update the assignment entry for this device location.</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Index" asp-controller="DeviceLocation" class="btn btn-outline-secondary">Back to Locations</a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <form asp-action="Edit" asp-route-id="@Model.Id" method="post" novalidate>
                <input asp-for="Id" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                @await Html.PartialAsync("_AutocompleteDropdown", new projekt.ViewModels.AutocompleteDropdownViewModel
                {
                    FieldName = "DeviceId",
                    TextFieldName = "DeviceName",
                    Label = "Device",
                    Value = Model.DeviceId,
                    SelectedText = Model.DeviceName,
                    Placeholder = "Search for a device...",
                    AutocompleteUrl = Url.Action("Autocomplete", "Device") ?? string.Empty,
                    Required = true
                })

                @await Html.PartialAsync("_AutocompleteDropdown", new projekt.ViewModels.AutocompleteDropdownViewModel
                {
                    FieldName = "LaboratoryId",
                    TextFieldName = "LaboratoryName",
                    Label = "Laboratory",
                    Value = Model.LaboratoryId,
                    SelectedText = Model.LaboratoryName,
                    Placeholder = "Search for a laboratory...",
                    AutocompleteUrl = Url.Action("Autocomplete", "Laboratory") ?? string.Empty,
                    Required = false
                })

                @await Html.PartialAsync("_DateTimeControl", new projekt.ViewModels.DateTimeControlViewModel
                {
                    FieldName = "AssignedDate",
                    Label = "Assigned Date",
                    Value = Model.AssignedDate,
                    Required = false
                })

                @await Html.PartialAsync("_DateTimeControl", new projekt.ViewModels.DateTimeControlViewModel
                {
                    FieldName = "RemovedDate",
                    Label = "Removed Date",
                    Value = Model.RemovedDate,
                    Required = false
                })

                <div class="form-check form-switch mb-3">
                    <input asp-for="IsCurrentLocation" class="form-check-input" />
                    <label asp-for="IsCurrentLocation" class="form-check-label"></label>
                </div>

                <div class="mb-3">
                    <label asp-for="AssignmentReason" class="form-label"></label>
                    <textarea asp-for="AssignmentReason" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="AssignmentReason" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
