@model List<projekt.Models.DeviceLocation>

@{
    ViewData["Title"] = "Device Locations";
}

<div class="container mt-5">
    <div class="row mb-4 align-items-end">
        <div class="col-md-6">
            <h1 class="display-5">Device Locations</h1>
            <p class="text-muted">Search, review and manage device assignments with live AJAX filtering.</p>
        </div>
        <div class="col-md-6 text-end">
            <a asp-action="Create" asp-controller="DeviceLocation" class="btn btn-primary">Add Location</a>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-8">
            <div class="input-group shadow-sm">
                <span class="input-group-text">Search</span>
                <input id="device-location-search" class="form-control" placeholder="Search device name, laboratory or reason" />
                <button id="device-location-search-clear" type="button" class="btn btn-outline-secondary">Clear</button>
            </div>
        </div>
    </div>

    <div id="device-location-table-container">
        @await Html.PartialAsync("_DeviceLocationTable", Model)
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            lab4.initSearch("#device-location-search", "#device-location-table-container", "@Url.Action("Search", "DeviceLocation")");
        });
    </script>
}
