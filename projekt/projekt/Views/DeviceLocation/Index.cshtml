@model List<projekt.Models.DeviceLocation>

@{
    ViewData["Title"] = "Device Locations";
}

<div class="container-fluid mt-5">
    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="display-5 fw-bold">
                <span class="badge bg-info">Device Locations</span>
            </h1>
            <p class="text-muted">View and manage all device locations across laboratories</p>
        </div>
        <div class="col-md-4 text-end">
            
        </div>
    </div>

    <!-- Content Section -->
    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <i class="bi bi-info-circle"></i>
            <strong>No device locations found.</strong> Get started by adding your first device location.
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    else
    {
        <!-- Table Section -->
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-3">
                <h5 class="card-title mb-0 fw-bold">
                    <i class="bi bi-map-fill"></i> Location Directory
                </h5>
            </div>
            <div class="card-body p-0">
                <!-- Table View -->
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th scope="col" class="ps-4 fw-bold text-muted text-uppercase small">ID</th>
                                <th scope="col" class="fw-bold text-muted text-uppercase small">Device ID</th>
                                <th scope="col" class="fw-bold text-muted text-uppercase small">Laboratory ID</th>
                                <th scope="col" class="fw-bold text-muted text-uppercase small">Location Description</th>
                                <th scope="col" class="text-end pe-4 fw-bold text-muted text-uppercase small">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var location in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <span class="badge bg-secondary">@location.Id</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-primary">@location.DeviceId</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-warning text-dark">@location.LaboratoryId</span>
                                    </td>
                                    <td>
                                        <strong>@location.AssignmentReason</strong>
                                    </td>
                                    <td class="text-end pe-4">
                                        <a href="@Url.Action("Details", "DeviceLocation", new { id = location.Id })" class="btn btn-sm btn-info">
                                            <i class="bi bi-eye"></i> Details
                                        </a>
                                        
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Summary Footer -->
        <div class="mt-4 text-muted small">
            <i class="bi bi-info-circle"></i>
            Showing <strong>@Model.Count</strong> device location@(Model.Count != 1 ? "s" : "")
        </div>
    }
</div>
